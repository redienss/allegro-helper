# Reference for the settings keys. Nothing reads this file.
#
# Settings live in ~/.allegro-helper/.env, which File > Settings writes for
# you — copy lines from here into it only if you would rather set them by hand.
# A .env in the base directory is still read (it is how this app used to be
# configured), but the settings file wins over it, and a real environment
# variable wins over both.

# OpenAI API key used to generate offer descriptions.
OPENAI_API_KEY=

# Model used to generate descriptions.
OPENAI_MODEL=gpt-4o-mini

# The directory the app opens on (File > Settings > Photos). A directory named
# on the command line wins over this; without either, the working directory.
# BASE_DIR=

# Where photos are imported from, and how they are grouped into offers — both
# on File > Settings > Photos. The photo directory defaults to the phone's
# OpenCamera folder over MTP; recognition is auto | single | subfolders.
# MTP_GLOB_PATTERN=
# SERIES_RECOGNITION=auto

# Optional: override the OpenAI-compatible API base URL (e.g. a proxy or Azure
# gateway). Defaults to https://api.openai.com/v1.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: override the prompts used to generate descriptions (defaults live
# in GenerateDescription.java). Easiest edited via File > Settings > OpenAI
# API, which stores multi-line values double-quoted with \n escapes. The user
# prompt should contain {{OFFER_JSON}} where the offer data goes.
# OPENAI_SYSTEM_PROMPT=
# OPENAI_USER_PROMPT=

# Optional: tesseract language(s) for the OCR step (needs the matching
# tesseract-ocr-<lang> packages installed). Defaults to pol+eng.
# OCR_LANGUAGES=pol+eng
