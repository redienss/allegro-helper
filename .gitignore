.env
build/
# Gradle's own caches. The wrapper (gradlew, gradle/wrapper/) IS committed, so
# a fresh clone can build without Gradle installed.
.gradle/
# Eclipse IDE project files
.classpath
.project
raw_photos/
offers/
more_data_*.txt
# The working offer list, edited by the app on every run. Copy offers.csv.dist
# to offers.csv to get started; the template is the versioned one.
offers.csv
.~lock.*#
# Chrome profile driven by "Copy all to Allegro" - holds the Allegro login session.
.chrome-profile/
# Reference copy of the Allegro form, saved while logged in (embeds account data).
allegro-form/
